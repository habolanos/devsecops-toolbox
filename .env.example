# ═══════════════════════════════════════════════════════════════════════════════
# Variables de Entorno - DevSecOps Toolbox
# ═══════════════════════════════════════════════════════════════════════════════
# Copia este archivo a .env y configura tus credenciales
# NUNCA subas el archivo .env real al repositorio (ya está en .gitignore)
# ═══════════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════════
# AZURE
# ═══════════════════════════════════════════════════════════════════════════════
# Para autenticación con Service Principal
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_SUBSCRIPTION_ID=your-azure-subscription-id

# Alternativa: usar az login interactivo (no requiere estas variables)
# AZURE_USE_INTERACTIVE_LOGIN=true

# ═══════════════════════════════════════════════════════════════════════════════
# AWS
# ═══════════════════════════════════════════════════════════════════════════════
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_DEFAULT_REGION=us-east-1
# Opcional: para tokens temporales (STS)
# AWS_SESSION_TOKEN=your-session-token

# ═══════════════════════════════════════════════════════════════════════════════
# GOOGLE CLOUD PLATFORM (GCP)
# ═══════════════════════════════════════════════════════════════════════════════
# Contenido del archivo JSON de service account en base64
# Para convertir: cat service-account.json | base64
GCP_SERVICE_ACCOUNT_KEY=your-base64-encoded-service-account-json
GCP_PROJECT_ID=your-gcp-project-id

# ═══════════════════════════════════════════════════════════════════════════════
# KUBERNETES
# ═══════════════════════════════════════════════════════════════════════════════
# Contenido del archivo kubeconfig en base64
# Para convertir: cat ~/.kube/config | base64
KUBECONFIG_CONTENT=your-base64-encoded-kubeconfig

# ═══════════════════════════════════════════════════════════════════════════════
# CONFIGURACIÓN OPCIONAL
# ═══════════════════════════════════════════════════════════════════════════════
# Zona horaria
TZ=America/Mexico_City

# Configuración de Python
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
